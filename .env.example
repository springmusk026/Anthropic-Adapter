# Copy this file to .env and adjust the values for your environment.

# Server
PORT=3000

# Provider
# Supported values: openai, mock
PROVIDER=openai

# Upstream provider settings
# Required when PROVIDER=openai.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional fallback model. Leave empty to pass the request model through.
OPENAI_DEFAULT_MODEL=

# Upstream timeout in milliseconds.
OPENAI_TIMEOUT=120000

# Client authentication
# Set AUTH_DISABLED=true only for local development or trusted internal use.
AUTH_DISABLED=false

# Comma-separated client API keys.
# If AUTH_DISABLED=false and this value is empty, the server still allows requests.
# Do not rely on that behavior in production.
API_KEYS=local-dev-key-1,local-dev-key-2

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Model mapping
# Format: client-model:provider-model,client-model:provider-model
MODEL_MAP=

# Retries
# Retries apply to retryable upstream failures such as 429 and 503 responses.
RETRY_COUNT=2
RETRY_DELAY_MS=1000

# CORS
# Use an explicit allowlist in production when browsers call this service directly.
CORS_ORIGINS=*

# Rate limiting
# Requests per minute per API key or client IP.
# Leave unset to disable the limiter.
# RATE_LIMIT_RPM=60

# Shutdown
SHUTDOWN_TIMEOUT_MS=5000
